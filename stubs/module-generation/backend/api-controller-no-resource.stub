<?php

declare(strict_types=1);

namespace App\Modules\{{ moduleNamespace }}\Http\Controllers;

use App\Http\Controllers\Controller;
use App\Models\{{ modelClass }};
use App\Modules\{{ moduleNamespace }}\Commands\{{ modelClass }}Commands;
use App\Modules\{{ moduleNamespace }}\Http\Requests\{{ pagePascalName }}StoreRequest;
use App\Modules\{{ moduleNamespace }}\Http\Requests\{{ pagePascalName }}UpdateRequest;
use App\Modules\{{ moduleNamespace }}\Queries\{{ modelClass }}Queries;
use Illuminate\Http\JsonResponse;

final class {{ pagePascalName }}ApiController extends Controller
{
    public function __construct(
        private readonly {{ modelClass }}Queries ${{ modelVariable }}Queries,
        private readonly {{ modelClass }}Commands ${{ modelVariable }}Commands,
    ) {}

    public function index(): JsonResponse
    {
        $paginator = $this->{{ modelVariable }}Queries->paginate();
        /** @var list<{{ modelClass }}> $models */
        $models = $paginator->items();

        return response()->json([
            'data' => array_map(static fn ({{ modelClass }} $model): array => $this->serializeModel($model), $models),
            'meta' => [
                'current_page' => $paginator->currentPage(),
                'last_page' => $paginator->lastPage(),
                'per_page' => $paginator->perPage(),
                'total' => $paginator->total(),
            ],
        ]);
    }

    public function store({{ pagePascalName }}StoreRequest $request): JsonResponse
    {
        $model = $this->{{ modelVariable }}Commands->create($request->toDto());

        return response()->json(['data' => $this->serializeModel($model)], 201);
    }

    public function show({{ modelClass }} ${{ modelVariable }}): JsonResponse
    {
        return response()->json(['data' => $this->serializeModel(${{ modelVariable }})]);
    }

    public function update({{ pagePascalName }}UpdateRequest $request, {{ modelClass }} ${{ modelVariable }}): JsonResponse
    {
        $model = $this->{{ modelVariable }}Commands->update(${{ modelVariable }}, $request->toDto());

        return response()->json(['data' => $this->serializeModel($model)]);
    }

    public function destroy({{ modelClass }} ${{ modelVariable }}): JsonResponse
    {
        $this->{{ modelVariable }}Commands->delete(${{ modelVariable }});

        return response()->json([], 204);
    }

    /**
     * @return array{id: int, name: string, created_at: string|null, updated_at: string|null}
     */
    private function serializeModel({{ modelClass }} $model): array
    {
        return [
            'id' => $model->id,
            'name' => $model->name,
            'created_at' => $model->created_at?->toISOString(),
            'updated_at' => $model->updated_at?->toISOString(),
        ];
    }
}
