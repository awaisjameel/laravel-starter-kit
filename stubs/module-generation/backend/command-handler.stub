<?php

declare(strict_types=1);

namespace App\Modules\{{ moduleNamespace }}\Handlers;

use App\Models\{{ modelClass }};
use App\Modules\{{ moduleNamespace }}\Commands\{{ modelClass }}Commands;
use App\Modules\{{ moduleNamespace }}\Data\{{ storeDataClass }};

final readonly class {{ modelClass }}CommandHandler
{
    public function __construct(
        private {{ modelClass }}Commands ${{ modelVariable }}Commands,
    ) {}

    public function create({{ storeDataClass }} $storeData): {{ modelClass }}
    {
        return $this->{{ modelVariable }}Commands->create($storeData);
    }

    public function update({{ modelClass }} $model, {{ storeDataClass }} $storeData): {{ modelClass }}
    {
        return $this->{{ modelVariable }}Commands->update($model, $storeData);
    }

    public function delete({{ modelClass }} $model): void
    {
        $this->{{ modelVariable }}Commands->delete($model);
    }
}
